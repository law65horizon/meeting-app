rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isUserInMeeting(meetingData) {
      return isAuthenticated() && (
        request.auth.uid == meetingData.hostId || 
        request.auth.token.email == meetingData.recipientEmail
      );
    }

    // Meetings collection rules
    match /meetings/{meetingId} {
      // Allow creation if user is authenticated
      allow create: if isAuthenticated();
      
      // Allow read if user is either the host or recipient
      allow read: if isAuthenticated() && (
        resource.data.hostId == request.auth.uid || 
        resource.data.recipientEmail == request.auth.token.email
      );
      
      // Allow updates if user is part of the meeting
      allow update: if isAuthenticated() && (
        resource.data.hostId == request.auth.uid || 
        resource.data.recipientEmail == request.auth.token.email
      ) && (
        // Only allow updating specific fields
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['offer', 'answer', 'hostCandidates', 'recipientCandidates', 'status', 'participants'])
      );

      // Allow deletion only by the host
      allow delete: if isAuthenticated() && 
        resource.data.hostId == request.auth.uid;
    }
  }
}